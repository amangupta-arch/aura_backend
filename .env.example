# Port for the Express server
PORT=3000

# Path to the Google service-account JSON key file.
# Create a service account in Google Cloud, enable the Drive API,
# share the destination Drive folder with the service account email,
# then download the JSON key and point this at it.
GOOGLE_SERVICE_ACCOUNT_KEY_FILE=./service-account.json

# ID of the Google Drive folder that receives the uploads.
# Copy the folder ID from the share URL:
# https://drive.google.com/drive/folders/<THIS_PART>
GOOGLE_DRIVE_FOLDER_ID=your_drive_folder_id_here

# SQLite database file location
DB_FILE=./data/aura.db
